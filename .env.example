NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
FANTASY_DATABASE_API_SECRET=
# Optional alternative. A Supabase secret/service-role key also works, but grants broader access.
SUPABASE_SECRET_KEY=
# Temporada activa de LaLiga (año de inicio). Cambia a 2026 al arrancar la 2026-27.
LALIGA_SEASON=2025
# Respaldo / segunda fuente de datos.
# football-data.org (gratis): calendario, resultados y clasificación de LaLiga.
FOOTBALL_DATA_TOKEN=
# API-Football (api-sports.io): estadísticas por jugador. OJO: el plan gratis solo
# cubre 2022-2024, no la temporada en curso; requiere plan de pago para usarlo en vivo.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LALIGA_ID=140
API_FOOTBALL_SEASON=2025
CRON_SECRET=
